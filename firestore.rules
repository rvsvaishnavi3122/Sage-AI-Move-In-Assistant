rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3 Primitives
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation Blueprint for UserProfile
    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'username', 'countryCode', 'currency', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.username is string && data.username.size() >= 3 && data.username.size() <= 30 &&
             data.countryCode is string && data.countryCode.size() == 2 &&
             data.currency is string && data.currency.size() == 3 &&
             data.createdAt == request.time;
    }

    // 6. PII Isolation (Implicit in isOwner check for the whole document)
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // No public listing of users
      
      allow create: if isOwner(userId) && isValidUserProfile(incoming());
      
      allow update: if isOwner(userId) && 
                    isValidUserProfile(incoming()) && (
                      // Only allow updating specific fields to prevent state tampering
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'username', 'countryCode', 'currency']) &&
                      incoming().uid == existing().uid &&
                      incoming().createdAt == existing().createdAt
                    );
    }
  }
}
